<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_materials>
    <material id="Mat_building" name="building">
      <instance_effect url="#Mat_building_effect"/>
    </material>
  </library_materials>
  <library_effects>
    <effect id="Mat_building_effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse><color>0.72 0.65 0.55 1</color></diffuse>
            <specular><color>0.05 0.05 0.05 1</color></specular>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_geometries>
    <geometry id="geo_The Swan Inn" name="The Swan Inn">
      <mesh>
        <source id="geo_The Swan Inn_pos">
          <float_array id="geo_The Swan Inn_pos_arr" count="48">-276.988 -253.997 73.349 -270.914 -251.485 73.349 -255.724 -269.901 73.349 -273.488 -280.115 73.349 -276.988 -275.703 73.349 -271.833 -271.290 73.349 -282.143 -259.498 73.349 -274.963 -255.475 73.349 -276.988 -253.997 81.349 -270.914 -251.485 81.349 -255.724 -269.901 81.349 -273.488 -280.115 81.349 -276.988 -275.703 81.349 -271.833 -271.290 81.349 -282.143 -259.498 81.349 -274.963 -255.475 81.349</float_array>
          <technique_common>
            <accessor source="#geo_The Swan Inn_pos_arr" count="16" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="geo_The Swan Inn_verts">
          <input semantic="POSITION" source="#geo_The Swan Inn_pos"/>
        </vertices>
        <triangles count="22" material="Mat_building">
          <input semantic="VERTEX" source="#geo_The Swan Inn_verts" offset="0"/>
          <p>0 1 9 0 9 8 1 2 10 1 10 9 2 3 11 2 11 10 3 4 12 3 12 11 4 5 13 4 13 12 5 6 14 5 14 13 6 7 15 6 15 14 7 0 8 7 8 15 15 9 8 15 10 9 10 12 11 10 13 12 15 13 10 13 15 14</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="Building" name="The Swan Inn" type="NODE">
        <instance_geometry url="#geo_The Swan Inn">
          <bind_material>
            <technique_common>
              <instance_material symbol="Mat_building" target="#Mat_building"/>
            </technique_common>
          </bind_material>
