<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_materials>
    <material id="Mat_building" name="building">
      <instance_effect url="#Mat_building_effect"/>
    </material>
  </library_materials>
  <library_effects>
    <effect id="Mat_building_effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse><color>0.72 0.65 0.55 1</color></diffuse>
            <specular><color>0.05 0.05 0.05 1</color></specular>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_geometries>
    <geometry id="geo_Bourchiers" name="Bourchiers">
      <mesh>
        <source id="geo_Bourchiers_pos">
          <float_array id="geo_Bourchiers_pos_arr" count="60">-1053.975 805.591 80.982 -1044.496 793.088 80.982 -1037.927 798.067 80.982 -1042.169 803.668 80.982 -1037.303 807.347 80.982 -1035.587 805.091 80.982 -1030.727 808.770 80.982 -1032.759 811.448 80.982 -1021.097 820.284 80.982 -1026.011 826.763 80.982 -1053.975 805.591 88.982 -1044.496 793.088 88.982 -1037.927 798.067 88.982 -1042.169 803.668 88.982 -1037.303 807.347 88.982 -1035.587 805.091 88.982 -1030.727 808.770 88.982 -1032.759 811.448 88.982 -1021.097 820.284 88.982 -1026.011 826.763 88.982</float_array>
          <technique_common>
            <accessor source="#geo_Bourchiers_pos_arr" count="20" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="geo_Bourchiers_verts">
          <input semantic="POSITION" source="#geo_Bourchiers_pos"/>
        </vertices>
        <triangles count="28" material="Mat_building">
          <input semantic="VERTEX" source="#geo_Bourchiers_verts" offset="0"/>
          <p>0 1 11 0 11 10 1 2 12 1 12 11 2 3 13 2 13 12 3 4 14 3 14 13 4 5 15 4 15 14 5 6 16 5 16 15 6 7 17 6 17 16 7 8 18 7 18 17 8 9 19 8 19 18 9 0 10 9 10 19 10 11 12 10 12 13 19 10 13 19 13 14 19 14 15 15 16 17 19 15 17 17 18 19</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="Building" name="Bourchiers" type="NODE">
        <instance_geometry url="#geo_Bourchiers">
          <bind_material>
            <technique_common>
              <instance_material symbol="Mat_building" target="#Mat_building"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
