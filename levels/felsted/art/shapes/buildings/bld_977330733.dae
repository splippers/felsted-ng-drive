<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_materials>
    <material id="Mat_building" name="building">
      <instance_effect url="#Mat_building_effect"/>
    </material>
  </library_materials>
  <library_effects>
    <effect id="Mat_building_effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse><color>0.72 0.65 0.55 1</color></diffuse>
            <specular><color>0.05 0.05 0.05 1</color></specular>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_geometries>
    <geometry id="geo_Felsted School Sports Centre" name="Felsted School Sports Centre">
      <mesh>
        <source id="geo_Felsted School Sports Centre_pos">
          <float_array id="geo_Felsted School Sports Centre_pos_arr" count="36">135.639 216.877 73.862 163.431 200.695 73.862 153.657 183.913 73.862 148.296 187.036 73.862 128.816 198.383 73.862 125.864 200.106 73.862 135.639 216.877 85.862 163.431 200.695 85.862 153.657 183.913 85.862 148.296 187.036 85.862 128.816 198.383 85.862 125.864 200.106 85.862</float_array>
          <technique_common>
            <accessor source="#geo_Felsted School Sports Centre_pos_arr" count="12" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="geo_Felsted School Sports Centre_verts">
          <input semantic="POSITION" source="#geo_Felsted School Sports Centre_pos"/>
        </vertices>
        <triangles count="16" material="Mat_building">
          <input semantic="VERTEX" source="#geo_Felsted School Sports Centre_verts" offset="0"/>
          <p>0 1 7 0 7 6 1 2 8 1 8 7 2 3 9 2 9 8 3 4 10 3 10 9 4 5 11 4 11 10 5 0 6 5 6 11 11 7 6 11 8 7 11 9 8 9 11 10</p>
