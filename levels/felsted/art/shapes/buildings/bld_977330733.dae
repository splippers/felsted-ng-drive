  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="Building" name="Felsted School Sports Centre" type="NODE">
        <instance_geometry url="#geo_Felsted School Sports Centre">
          <bind_material>
            <technique_common>
              <instance_material symbol="Mat_building" target="#Mat_building"/>
            </technique_common>
          </bind_material>
